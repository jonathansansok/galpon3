//backend\prisma\schema.prisma
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Ingresos {
  id                        Int       @id @default(autoincrement()) // Clave primaria autoincremental
  uuid                      String    @unique @default(uuid()) @db.VarChar(36)
  lpu                       String?   @db.VarChar(50) // Puede cambiar
  identificadorUnico        String?   @unique @db.VarChar(255) // Clave única adicional
  createdAt                 DateTime? @default(now()) // TIMESTAMP con valor por defecto
  updatedAt                 DateTime? @default(now()) // TIMESTAMP con valor por defecto
  email                     String?   @db.VarChar(255) // VARCHAR(255)
  cp                        String?   @db.VarChar(255) // VARCHAR(255)
  telefono                  String?   @db.VarChar(255) // Campo teléfono, puede ser cualquier texto o null
  emailCliente              String?   @db.VarChar(255)
  numeroCuit                String?   @db.VarChar(20) // Número de CUIT
  dias                      String?   @db.VarChar(10) // Días
  iva                       String?   @db.VarChar(50) // Condición frente al IVA
  pyme                      String?   @db.VarChar(5) // Indica si es PyME
  porcB                     String?   @db.VarChar(10) // Porcentaje B
  porcRetIB                 String?   @db.VarChar(10) // Porcentaje Retención IB
  imagen                    String?   @db.VarChar(255) // VARCHAR(255)
  imagenDer                 String?   @db.VarChar(255)
  imagenIz                  String?   @db.VarChar(255)
  imagenDact                String?   @db.VarChar(255)
  imagenSen1                String?   @db.VarChar(255)
  imagenSen2                String?   @db.VarChar(255)
  imagenSen3                String?   @db.VarChar(255)
  imagenSen4                String?   @db.VarChar(255)
  imagenSen5                String?   @db.VarChar(255)
  imagenSen6                String?   @db.VarChar(255)
  pdf1                      String?   @db.VarChar(255)
  pdf2                      String?   @db.VarChar(255)
  pdf3                      String?   @db.VarChar(255)
  pdf4                      String?   @db.VarChar(255)
  pdf5                      String?   @db.VarChar(255)
  pdf6                      String?   @db.VarChar(255)
  pdf7                      String?   @db.VarChar(255)
  pdf8                      String?   @db.VarChar(255)
  pdf9                      String?   @db.VarChar(255)
  pdf10                     String?   @db.VarChar(255)
  word1                     String?   @db.VarChar(255)
  imagenes                  String? // LONGTEXT opcional
  condicion                 String?   @db.VarChar(20)
  historialEgresos          Json?     @default("[]") // Historial de egresos como JSON
  unidadDeIngreso           String?   @db.VarChar(40) // VARCHAR(40)
  fechaHoraIng              DateTime? @db.DateTime // DATETIME
  apellido                  String?   @db.VarChar(150) // VARCHAR(150)
  nombres                   String?   @db.VarChar(255) // VARCHAR(255)
  alias                     String?   @db.VarChar(100) // VARCHAR(100) opcional
  tipoDoc                   String?   @db.VarChar(12) // VARCHAR(12)
  numeroDni                 String?   @db.VarChar(50) // VARCHAR(50)
  docNacionalidad           String?   @db.VarChar(100)
  fechaNacimiento           DateTime? @db.DateTime // DATE
  edad_ing                  String?   @db.VarChar(5) // INT
  nacionalidad              String?   @db.VarChar(40) // VARCHAR(40)
  provincia                 String?   @db.VarChar(100) // VARCHAR(100)
  domicilios                String?   @db.LongText // Cambiado a texto
  numeroCausa               String?   @db.VarChar(255) // VARCHAR(50) opcional
  procedencia               String?   @db.VarChar(100) // VARCHAR(100) opcional
  orgCrim                   String?   @db.VarChar(50) // VARCHAR(50) opcional
  cualorg                   String?   @db.VarChar(100) // VARCHAR(100) opcional
  profesion                 String?   @db.VarChar(100) // VARCHAR(100) opcional
  perfil                    Json?
  esAlerta                  String?   @db.VarChar(3) // Definir la columna esAlerta como Boolean
  reingreso                 String?   @db.LongText // LONGTEXT
  establecimiento           String?   @db.VarChar(200) // VARCHAR(40)
  modulo_ur                 String?   @db.VarChar(60)
  pabellon                  String?   @db.VarChar(70)
  celda                     String?   @db.VarChar(70)
  historial                 String?   @db.LongText // LONGTEXT
  titInfoPublic             String?   @db.LongText // VARCHAR(255) opcional
  resumen                   String?   @db.LongText // TEXT opcional
  observacion               String? // TEXT opcional
  link                      String?   @db.LongText // VARCHAR(255) opcional
  patologias                Json?
  tatuajes                  Json?
  cicatrices                Json?
  ubicacionMap              String?   @db.LongText // LONGTEXT
  electrodomesticos         Json?
  electrodomesticosDetalles String?   @db.LongText // TEXT opcional
  juzgados                  Json?
  sitProc                   String?   @db.VarChar(20)
  lpuProv                   String?   @db.VarChar(50) // VARCHAR(50) opcional
  subGrupo                  String?   @db.VarChar(40) // VARCHAR(40) opcional
  sexo                      String?   @db.VarChar(10) // VARCHAR(10) opcional
  sexualidad                String?   @db.VarChar(30) // VARCHAR(30) opcional
  temaInf                   String? // VARCHAR(30) opcional
  estadoCivil               String?   @db.VarChar(30) // VARCHAR(30) opcional
  internosinvolucrado       String?   @db.LongText
  imagenesHistorial         Json? // Historial de imágenes
  nombresOriginales         Json? // Nombres originales de archivos subidos
  moviles                   Temas[]
}

model Temas {
  id                  Int       @id @default(autoincrement())
  uuid                String    @unique @default(uuid()) @db.VarChar(36)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  fechaHora           DateTime?
  observacion         String?
  email               String?
  patente             String?
  marca               String?
  modelo              String?
  anio                String? // Cambiado de Int a String
  color               String?
  tipoPintura         String?
  paisOrigen          String?
  tipoVehic           String?
  motor               String?
  chasis              String?
  combustion          String?
  vin                 String?
  imagen              String?   @db.VarChar(255) // VARCHAR(255)
  imagenDer           String?   @db.VarChar(255)
  imagenIz            String?   @db.VarChar(255)
  imagenDact          String?   @db.VarChar(255)
  imagenSen1          String?   @db.VarChar(255)
  imagenSen2          String?   @db.VarChar(255)
  imagenSen3          String?   @db.VarChar(255)
  imagenSen4          String?   @db.VarChar(255)
  imagenSen5          String?   @db.VarChar(255)
  imagenSen6          String?   @db.VarChar(255)
  pdf1                String?   @db.VarChar(255)
  pdf2                String?   @db.VarChar(255)
  pdf3                String?   @db.VarChar(255)
  pdf4                String?   @db.VarChar(255)
  pdf5                String?   @db.VarChar(255)
  pdf6                String?   @db.VarChar(255)
  pdf7                String?   @db.VarChar(255)
  pdf8                String?   @db.VarChar(255)
  pdf9                String?   @db.VarChar(255)
  pdf10               String?   @db.VarChar(255)
  word1               String?   @db.VarChar(255)
  internosinvolucrado String?   @db.Text
  nombresOriginales   Json? // Nombres originales de archivos subidos
  clienteId           Int?
  cliente             Ingresos? @relation(fields: [clienteId], references: [id])
}

model Presupuestos {
  id            Int      @id @default(autoincrement())
  uuid          String   @unique @default(uuid()) @db.VarChar(36)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  movilId       String?
  patente       String?
  monto         String?
  estado        String   @default("Pendiente")
  observaciones String?
  // Campos de archivos multimedia
  imagen        String?  @db.VarChar(255)
  imagenDer     String?  @db.VarChar(255)
  imagenIz      String?  @db.VarChar(255)
  imagenDact    String?  @db.VarChar(255)
  imagenSen1    String?  @db.VarChar(255)
  imagenSen2    String?  @db.VarChar(255)
  imagenSen3    String?  @db.VarChar(255)
  imagenSen4    String?  @db.VarChar(255)
  imagenSen5    String?  @db.VarChar(255)
  imagenSen6    String?  @db.VarChar(255)
  pdf1          String?  @db.VarChar(255)
  pdf2          String?  @db.VarChar(255)
  pdf3          String?  @db.VarChar(255)
  pdf4          String?  @db.VarChar(255)
  pdf5          String?  @db.VarChar(255)
  pdf6          String?  @db.VarChar(255)
  pdf7          String?  @db.VarChar(255)
  pdf8          String?  @db.VarChar(255)
  pdf9          String?  @db.VarChar(255)
  pdf10         String?  @db.VarChar(255)
  word1         String?  @db.VarChar(255)
}

model Marcas {
  id                  Int      @id @default(autoincrement())
  uuid                String   @unique @default(uuid()) @db.VarChar(36)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  value               String   @db.VarChar(500)
  label               String   @db.VarChar(500)
  internosinvolucrado String?  @db.Text
  email               String?  @db.VarChar(100)
  modelos             Modelo[] // Relación con los modelos
}

model Modelo {
  id        Int      @id @default(autoincrement())
  uuid      String   @unique @default(uuid()) @db.VarChar(36)
  label     String   @db.VarChar(500)
  value     String   @db.VarChar(500)
  marcaId   Int      // Relación con la marca
  marca     Marcas   @relation(fields: [marcaId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Users {
  id                  Int        @id @default(autoincrement())
  uuid                String     @unique @default(uuid()) @db.VarChar(36)
  email               String     @unique
  password            String     @db.VarChar(255)
  nombre              String?    @db.VarChar(255)
  apellido            String?    @db.VarChar(255)
  telefono            String?    @db.VarChar(255)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  privilege           String?
  internosinvolucrado String?    @db.Text
  comp                String?    @db.VarChar(255)
  status              String     @default("PENDIENTE") @db.VarChar(20)
  resetToken          String?    @db.VarChar(255)
  resetTokenExpiry    DateTime?
  auditLogs           AuditLog[]
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  uuid       String   @unique @default(uuid()) @db.VarChar(36)
  action     String   @db.VarChar(10) // CREATE, UPDATE, DELETE
  entity     String   @db.VarChar(100) // e.g. "Ingresos", "Temas"
  entityId   Int?
  entityUuid String?  @db.VarChar(36)
  detail    String?  @db.Text
  userId    Int?
  user      Users?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  readBy    Json?    @default("[]") // array of userIds that have read this
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

model Turnos {
  id                       Int       @id @default(autoincrement())
  uuid                     String    @unique @default(uuid()) @db.VarChar(36)
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  presupuestoId            String?   @db.VarChar(36)
  plaza                    Int
  fechaHoraInicioEstimada  DateTime
  fechaHoraFinEstimada     DateTime
  fechaHoraInicioReal      DateTime?
  fechaHoraFinReal         DateTime?
  estado                   String    @default("Programado")
  observaciones            String?   @db.Text
}
